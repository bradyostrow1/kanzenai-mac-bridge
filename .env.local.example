# Anthropic API key — drives the article writer in scripts/write-article.ts
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override default model (defaults to Sonnet 4.5)
# KANZENAI_MODEL=claude-sonnet-4-5-20250929

# ─── Newsletter provider (optional, pick one) ───────────────────────
# Resend Audiences (https://resend.com — 3k free)
# RESEND_API_KEY=re_...
# RESEND_AUDIENCE_ID=...

# Beehiiv (https://beehiiv.com)
# BEEHIIV_API_KEY=...
# BEEHIIV_PUBLICATION_ID=pub_...
