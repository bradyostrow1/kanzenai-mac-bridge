# AffiliateAI Boilerplate — environment variables
# Copy this file to .env.local and fill in your keys

# ─── Required ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...           # console.anthropic.com
PEXELS_API_KEY=...                            # pexels.com/api

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...                         # resend.com
RESEND_AUDIENCE_ID=...                        # create at resend.com/audiences
RESEND_FROM=hello@yourdomain.com              # must be verified in Resend

# ─── X (Twitter) — for auto-tweet bots ────────────────────────
# Get all 5 at developer.x.com → Apps → Keys & Tokens
# Note: Pay-Per-Use plan. Posting is cheap ($0.0001/tweet).
# Leave auto-reply / x-monitor OFF unless you can spare $20-50/mo.
X_CONSUMER_KEY=...
X_CONSUMER_SECRET=...
X_ACCESS_TOKEN=...                            # OAuth 1.0a access token (Read+Write)
X_ACCESS_TOKEN_SECRET=...
X_BEARER_TOKEN=...                            # for some app-only read endpoints
X_CLIENT_ID=...                               # OAuth 2.0 (only needed for future PKCE features)
X_CLIENT_SECRET=...

# ─── Optional: boilerplate self-promo on each auto-tweet ──────
# Set to 1 only if you forked this to sell your own version
BOILERPLATE_PROMO=0
