# AffiliateAI Boilerplate — environment variables
# Copy this file to .env.local and fill in your keys

# ─── Required ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...           # console.anthropic.com
PEXELS_API_KEY=...                            # pexels.com/api

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...                         # resend.com
RESEND_AUDIENCE_ID=...                        # create at resend.com/audiences
RESEND_FROM=hello@yourdomain.com              # must be verified in Resend

# ─── X (Twitter) — for auto-tweet bots ────────────────────────
# Get all 5 at developer.x.com → Apps → Keys & Tokens
# Note: Pay-Per-Use plan. Posting is cheap ($0.0001/tweet).
# Leave auto-reply / x-monitor OFF unless you can spare $20-50/mo.
X_CONSUMER_KEY=...
X_CONSUMER_SECRET=...
X_ACCESS_TOKEN=...                            # OAuth 1.0a access token (Read+Write)
X_ACCESS_TOKEN_SECRET=...
X_BEARER_TOKEN=...                            # for some app-only read endpoints
X_CLIENT_ID=...                               # OAuth 2.0 (only needed for future PKCE features)
X_CLIENT_SECRET=...

# ─── Telegram alerts (vendor-approval-tracker + affiliate-link-guard) ─
# Bot token from @BotFather; channel id is "@channelname" or numeric -100...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_HOME_CHANNEL=...

# ─── Affiliate networks (paste each as it gets approved) ──────────
# vendor-approval-tracker silently skips any network without keys.
# PartnerStack covers Copy.ai, Writesonic, Rytr, Kit (ConvertKit) and most
# other AI-tool-shopper programs. Get the API key at app.partnerstack.com.
PARTNERSTACK_API_KEY=...

# Other networks — fill as Brady gets approved:
# AWIN_API_TOKEN=...
# AWIN_PUBLISHER_ID=...
# SHAREASALE_TOKEN=...
# SHAREASALE_SECRET=...
# SHAREASALE_AFFILIATE_ID=...
# IMPACT_ACCOUNT_SID=...
# IMPACT_AUTH_TOKEN=...
# CJ_DEV_KEY=...
# CJ_PUBLISHER_ID=...
# REFERSION_API_KEY=...

# ─── Meta ads (Bots 8 + 9 — DO NOT FILL until affiliates earn) ────
# Both bots are specced only. Adding values here does NOT enable them —
# they have to be built first. See scripts/specs/bot-08-ad-creative.md
# and scripts/specs/bot-09-meta-poster.md.
# META_ACCESS_TOKEN=...                       # long-lived system-user token
# META_AD_ACCOUNT_ID=act_...                  # numeric ad account id
# META_APP_ID=...
# META_APP_SECRET=...                         # for token refresh
# META_PAGE_ID=...                            # the page ads run from
# META_CAMPAIGN_DAILY_USD_MAX=10              # hard kill-switch per campaign
# META_ACCOUNT_DAILY_USD_MAX=25               # hard kill-switch per account
# META_ACCOUNT_WEEKLY_USD_MAX=100             # weekly ceiling
